From 8f699901f9718be1a7c0e487387f48edbcffcee7 Mon Sep 17 00:00:00 2001
From: Dineshkumar Loganathan <dineshloganathan395@gmail.com>
Date: Sat, 10 Jan 2026 20:28:02 +0530
Subject: [PATCH 1/3] filogic: Fix build failure due to initramfs image size
 limit for BPI-R4 target

Observing build failure after enabling libndpi & netifyd packages in prplOS build
due to initramfs image size limit.

Increase the initramfs recovery image size limit for BPI-R4 from 44 MB to 64 MB
to fix build issues due to size check failures.

Signed-off-by: Dineshkumar Loganathan <dineshloganathan395@gmail.com>
---
 mediatek/image/filogic.mk | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mediatek/image/filogic.mk b/mediatek/image/filogic.mk
index 1a53263..eeb20fa 100644
--- a/mediatek/image/filogic.mk
+++ b/mediatek/image/filogic.mk
@@ -485,7 +485,7 @@ define Device/bananapi_bpi-r4-common
 				   pad-to 17k | mt7988-bl2 sdmmc-comb |\
 				   pad-to 6656k | mt7988-bl31-uboot $$(DEVICE_NAME)-sdmmc |\
 				$(if $(CONFIG_TARGET_ROOTFS_INITRAMFS),\
-				   pad-to 12M | append-image-stage initramfs-recovery.itb | check-size 44m |\
+				   pad-to 12M | append-image-stage initramfs-recovery.itb | check-size 64m |\
 				) \
 				   pad-to 44M | mt7988-bl2 spim-nand-ubi-comb |\
 				   pad-to 45M | mt7988-bl31-uboot $$(DEVICE_NAME)-snand |\
-- 
2.43.0

